# Required for all API calls (read-only access is sufficient)
X_BEARER_TOKEN=your_x_bearer_token_here

# Only needed if you extend the client to write tweets or DMs
# X_API_KEY=your_x_api_key_here
# X_API_SECRET=your_x_api_secret_here
# X_ACCESS_TOKEN=your_x_access_token_here
# X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

DATABASE_PATH=data/feed_cleaner.db
MONTHLY_BUDGET=10000

# ── Scraper (twscrape) — optional, reduces paid API usage ──────────────────
# Add 3-5 throwaway X accounts. Format: handle:password:email:email_password
# Comma-separate multiple accounts.
# Leave blank to use paid API only (SEARCH_MODE=api will be enforced).
# SCRAPER_ACCOUNTS=handle1:pass1:email1@gmail.com:emailpass1,handle2:pass2:email2@gmail.com:emailpass2

# scraper_with_fallback  → try scraper, fall back to paid API if sparse/down (default)
# scraper                → free scraper only, no paid API fallback
# api                    → paid API only, ignore scraper
SEARCH_MODE=scraper_with_fallback
